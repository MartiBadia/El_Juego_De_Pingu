<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.text.Text?>

<StackPane
    xmlns="http://javafx.com/javafx/21.0.10"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="vista.PantallaJuego"
    stylesheets="/resources/PantallaJuego.css"
    styleClass="root"
    prefWidth="1100" prefHeight="780">

    <Region styleClass="scene-background" />

    <BorderPane pickOnBounds="false">

    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="🎮 Partida">
                    <items>
                        <MenuItem fx:id="newGame"  mnemonicParsing="false" text="🆕  Nueva Partida" onAction="#handleNewGame"/>
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" text="💾  Guardar"       onAction="#handleSaveGame"/>
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" text="📂  Cargar"        onAction="#handleLoadGame"/>
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" text="🚪  Salir"         onAction="#handleQuitGame"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER" styleClass="bottom-bar">
                <padding><Insets top="8" bottom="4"/></padding>
                <Label text="🐧  EL JUEGO DE PINGU  🐧" styleClass="card-title"
                       style="-fx-font-size:18px; -fx-effect: dropshadow(gaussian, rgba(79,195,247,0.8), 10, 0.5, 0, 0);"/>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="12" right="16" bottom="0" left="16"/>
                </padding>

                <GridPane fx:id="tablero" styleClass="board"
                          maxHeight="Infinity" maxWidth="Infinity">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="20.0" />
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                        <RowConstraints percentHeight="10.0" />
                    </rowConstraints>

                    <children>
                        <StackPane GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="board-cell">
                             <Text text="🏁 START" styleClass="cell-title" />
                        </StackPane>
                        <StackPane GridPane.columnIndex="4" GridPane.rowIndex="9" styleClass="board-cell">
                             <Text text="🏆 FINISH" styleClass="cell-title" />
                        </StackPane>

                        <!-- Fichas de jugadores (Skins) -->
                        <ImageView fx:id="P1" id="P1" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false" />
                        <ImageView fx:id="P2" id="P2" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false">
                            <GridPane.margin><Insets left="20.0" /></GridPane.margin>
                        </ImageView>
                        <ImageView fx:id="P3" id="P3" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false">
                            <GridPane.margin><Insets left="40.0" /></GridPane.margin>
                        </ImageView>
                        <ImageView fx:id="P4" id="P4" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false">
                            <GridPane.margin><Insets left="60.0" /></GridPane.margin>
                        </ImageView>

                        <!-- Fichas de focas -->
                        <ImageView fx:id="PFoca" id="PFoca" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false">
                            <GridPane.margin><Insets left="80.0" /></GridPane.margin>
                        </ImageView>
                        <ImageView fx:id="PFoca2" id="PFoca2" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false">
                            <GridPane.margin><Insets left="100.0" top="10.0"/></GridPane.margin>
                        </ImageView>
                        <ImageView fx:id="PFoca3" id="PFoca3" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false">
                            <GridPane.margin><Insets left="120.0" top="20.0"/></GridPane.margin>
                        </ImageView>
                        <ImageView fx:id="PFoca4" id="PFoca4" fitWidth="45" fitHeight="45" preserveRatio="true" visible="false">
                            <GridPane.margin><Insets left="140.0" top="30.0"/></GridPane.margin>
                        </ImageView>
                    </children>
                </GridPane>
            </StackPane>
        </VBox>
    </center>

    <bottom>
        <VBox spacing="0">
            <HBox spacing="20" alignment="CENTER_LEFT" styleClass="bottom-bar"
                  style="-fx-border-width: 1 0 1 0; -fx-border-color: #1a3557; -fx-padding: 6 18;">
                <Label text="Turno actual gestionado por skins" style="-fx-text-fill:#a8c8e8; -fx-font-size:12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="turnLabel" text="▶ Turno de: Jugador 1"
                       style="-fx-text-fill:#4fc3f7; -fx-font-size:13px; -fx-font-weight:bold;"/>
            </HBox>

            <HBox spacing="14" styleClass="bottom-bar">
                <padding><Insets top="14" right="16" bottom="16" left="16"/></padding>

                <VBox spacing="10" styleClass="card" prefWidth="220">
                    <Label text="🎲  Dado" styleClass="card-title" />
                    <Text fx:id="dadoResultText" text="— Tira el dado —"
                          styleClass="big-text" wrappingWidth="185"/>
                    <Button fx:id="dado" text="🎲  Tirar Dado" onAction="#handleDado"
                            maxWidth="Infinity" styleClass="primary" />
                </VBox>

                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="🎒  Inventario" styleClass="card-title" />
                    <VBox spacing="8">
                        <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <Text fx:id="rapido_t" text="🎲  Dado Rápido: 0" styleClass="stat"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="rapido" text="Usar" onAction="#handleRapido"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <Text fx:id="lento_t"  text="🐢  Dado Lento: 0"  styleClass="stat"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="lento"  text="Usar" onAction="#handleLento"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <Text fx:id="peces_t"  text="🐟  Peces: 0"        styleClass="stat"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="peces"  text="Usar" onAction="#handlePeces"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <Text fx:id="nieve_t"  text="❄️  Bolas de Nieve: 0" styleClass="stat"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="nieve"  text="Usar" onAction="#handleNieve"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="10" styleClass="card" prefWidth="340" VBox.vgrow="ALWAYS">
                    <Label text="📋  Eventos" styleClass="card-title"/>
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                styleClass="objects-scroll" prefHeight="130" VBox.vgrow="ALWAYS">
                        <content>
                            <Text fx:id="eventos" text="¡El juego está listo! 🐧"
                                  styleClass="events" wrappingWidth="305"/>
                        </content>
                    </ScrollPane>
                </VBox>

            </HBox>
        </VBox>
    </bottom>

    </BorderPane>

    <Button fx:id="hamburgerButton" text="☰" onAction="#toggleMenu" 
            StackPane.alignment="TOP_RIGHT" styleClass="hamburger-button">
        <StackPane.margin>
            <Insets top="10" right="10"/>
        </StackPane.margin>
    </Button>

    <VBox fx:id="menuOverlay" visible="false" managed="false" spacing="15" 
          alignment="CENTER" styleClass="menu-overlay" maxWidth="300" maxHeight="400">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>
        <Label text="MENÚ" styleClass="card-title" style="-fx-font-size: 24px;"/>
        <Region prefHeight="10"/>
        <Button text="💾 Guardar Partida" onAction="#handleSaveGame" maxWidth="Infinity" styleClass="primary"/>
        <Button text="🏠 Salir al Menú" onAction="#handleGoToMenu" maxWidth="Infinity"/>
        <Button text="🚪 Cerrar Juego" onAction="#handleQuitGame" maxWidth="Infinity" style="-fx-opacity: 0.8;"/>
        <Region prefHeight="10"/>
        <Button text="Volver al Juego" onAction="#toggleMenu" maxWidth="Infinity" styleClass="secondary"/>
    </VBox>

</StackPane>