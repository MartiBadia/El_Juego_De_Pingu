<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane
    xmlns="http://javafx.com/javafx/21.0.10"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="vista.PantallaMenu"
    stylesheets="/resources/PantallaMenu.css"
    styleClass="root">

    <!-- Fondo de escena: Region estilizada por CSS -->
    <Region styleClass="scene-background" />

    <!-- Capa de la UI: BorderPane original -->
    <BorderPane pickOnBounds="false">

    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="newGame" mnemonicParsing="false" text="New" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" text="Save" />
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" text="Load" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" text="Quit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets top="28" right="28" bottom="28" left="28"/>
            </padding>

            <!-- CARD DE LOGIN -->
            <VBox fx:id="loginCard" spacing="16" styleClass="card" maxWidth="420" visible="true">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>
                
                <Label text="Bienvenido" styleClass="title"/>
                <Region prefHeight="8"/>

                <VBox spacing="10">
                    <Label text="Usuario" styleClass="field-label"/>
                    <TextField fx:id="userField" promptText="Usuario..." styleClass="field"/>

                    <Label text="Contraseña" styleClass="field-label"/>
                    <PasswordField fx:id="passField" promptText="Contraseña..." styleClass="field" onAction="#handleLogin"/>
                </VBox>

                <Region prefHeight="6"/>

                <HBox spacing="10">
                    <Button fx:id="loginButton" text="Entrar" onAction="#handleLogin" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="primary"/>
                    <Button fx:id="registerButton" text="Registro" onAction="#handleRegister" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <Label fx:id="feedbackLabel" text="Inicia sesión para jugar" styleClass="hint" alignment="CENTER" maxWidth="Infinity"/>
            </VBox>

            <!-- CARD DE SELECCIÓN (MENU PRINCIPAL) -->
            <VBox fx:id="optionsCard" spacing="20" styleClass="card" maxWidth="420" visible="false">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>
                
                <Label text="Menú Principal" styleClass="title"/>
                <Region prefHeight="10"/>

                <Button text="Crear Nueva Partida" onAction="#showConfigCard" maxWidth="Infinity" styleClass="primary" prefHeight="50"/>
                <Button text="Cargar Partida Guardada" onAction="#handleLoadGame" maxWidth="Infinity" prefHeight="50"/>
                <Button text="Cerrar Sesión" onAction="#handleLogout" maxWidth="Infinity" style="-fx-opacity: 0.8;"/>
                
                <Region prefHeight="10"/>
                <Label text="Elige una opción para comenzar" styleClass="hint" alignment="CENTER" maxWidth="Infinity"/>
            </VBox>

            <!-- CARD DE CONFIGURACIÓN -->
            <VBox fx:id="configCard" spacing="16" styleClass="card" maxWidth="450" visible="false">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>
                
                <Label text="Configurar Partida" styleClass="title"/>
                <Region prefHeight="8"/>

                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Pingüinos:" styleClass="field-label" prefWidth="150"/>
                        <TextField fx:id="playerCountField" text="2" prefWidth="60" styleClass="field"/>
                    </HBox>
                    
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Focas:" styleClass="field-label" prefWidth="150"/>
                        <TextField fx:id="sealCountField" text="1" prefWidth="60" styleClass="field"/>
                    </HBox>
                    
                    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px; -fx-font-weight: bold;" alignment="CENTER" maxWidth="Infinity"/>
                </VBox>

                <Region prefHeight="10"/>

                <HBox spacing="10">
                    <Button text="Volver" onAction="#showOptionsCard" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button text="Comenzar" onAction="#handleStartGame" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="primary"/>
                </HBox>
                
                <Label text="Configura el número de participantes" styleClass="hint" alignment="CENTER" maxWidth="Infinity"/>
            </VBox>

            <!-- CARD DE SELECCIÓN DE SKINS -->
            <VBox fx:id="skinSelectionCard" spacing="16" styleClass="card" maxWidth="450" visible="false">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>
                
                <Label fx:id="skinTitle" text="Jugador 1: Elige tu Skin" styleClass="title"/>
                <Region prefHeight="8"/>

                <VBox spacing="10">
                    <Label text="Tu Nombre:" styleClass="field-label"/>
                    <TextField fx:id="playerNameField" promptText="Escribe tu nombre..." styleClass="field"/>
                </VBox>

                <VBox spacing="20" alignment="CENTER">
                    <StackPane styleClass="skin-preview-container">
                        <ImageView fx:id="skinPreview" fitWidth="120" fitHeight="120" preserveRatio="true">
                            <Image url="/resources/skins/skin_dino.png"/>
                        </ImageView>
                    </StackPane>
                    
                    <HBox spacing="30" alignment="CENTER">
                        <Button text="◀" onAction="#handlePrevSkin" styleClass="arrow-button"/>
                        <Button text="▶" onAction="#handleNextSkin" styleClass="arrow-button"/>
                    </HBox>

                    <Button text="Confirmar Selección" onAction="#handleSelectCurrentSkin" maxWidth="Infinity" styleClass="primary" prefHeight="45"/>
                </VBox>

                <Label fx:id="skinErrorLabel" text="" style="-fx-text-fill: #ff6b6b;" alignment="CENTER" maxWidth="Infinity"/>

                <Region prefHeight="10"/>
                <Button text="Cancelar" onAction="#showConfigCard" maxWidth="Infinity"/>
            </VBox>

            <!-- CARD DE CARGA (LISTADO DE PARTIDAS) -->
            <VBox fx:id="loadGameCard" spacing="16" styleClass="card" maxWidth="450" visible="false">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>
                
                <Label text="Partidas Guardadas" styleClass="title"/>
                <Region prefHeight="8"/>

                <javafx.scene.control.ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 5;">
                    <VBox fx:id="gamesListContainer" spacing="10">
                        <!-- Los botones se generarán en el controlador -->
                    </VBox>
                </javafx.scene.control.ScrollPane>

                <Region prefHeight="10"/>

                <Button text="Volver" onAction="#showOptionsCard" maxWidth="Infinity" styleClass="secondary"/>
            </VBox>
        </StackPane>
    </center>

    </BorderPane>

</StackPane>